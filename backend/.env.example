# Supabase
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Internal API (camera worker, device)
INTERNAL_API_SECRET=

# App
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Patient AI (voice assistant)
# Whisper: runs locally; model is cached after first request for lower latency
# WHISPER_MODEL=base   # faster; use small or medium for better accuracy
# WHISPER_MODEL=small  # better accuracy, slower
# Leave WHISPER_LANGUAGE unset so both English and Malayalam are transcribed correctly.
# Setting WHISPER_LANGUAGE=ml forces Malayalam only and can make English speech appear as Malayalam.
# WHISPER_LANGUAGE=    # unset = auto-detect (recommended for English + Malayalam)
# OpenRouter: LLM (OSS models). Get key at https://openrouter.ai
# For free models: enable "Free model publication" at https://openrouter.ai/settings/privacy
OPENROUTER_API_KEY=
# If 429: try another free model or add provider key at https://openrouter.ai/settings/integrations
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
# AI_TEMP_DIR=  # optional; default is system temp
# TTS_VOICE=ml-IN-MidhunNeural  # Malayalam voice for edge-tts

# Face recognition: L2 distance below this = match. Default 0.45. Lower = stricter (fewer false positives).
# FACE_RECOGNITION_THRESHOLD=0.45
