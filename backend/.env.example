# Supabase
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Internal API (camera worker, device)
INTERNAL_API_SECRET=

# App
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Patient AI (voice assistant)
# Whisper: runs locally (openai-whisper), no API key needed
WHISPER_MODEL=base
# For better accuracy use: WHISPER_MODEL=small (or medium; slower)
# WHISPER_LANGUAGE=ml   # force Malayalam; leave unset for auto-detect (often more accurate)
# OpenRouter: LLM (OSS models). Get key at https://openrouter.ai
# For free models: enable "Free model publication" at https://openrouter.ai/settings/privacy
OPENROUTER_API_KEY=
# If 429: try another free model or add provider key at https://openrouter.ai/settings/integrations
OPENROUTER_MODEL=meta-llama/llama-3.2-3b-instruct:free
# AI_TEMP_DIR=  # optional; default is system temp
# TTS_VOICE=ml-IN-MidhunNeural  # Malayalam voice for edge-tts

# Face recognition: L2 distance below this = match. Default 0.45. Lower = stricter (fewer false positives).
# FACE_RECOGNITION_THRESHOLD=0.45
